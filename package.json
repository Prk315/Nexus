{
  "name": "nexus-ecosystem",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/Vault/Vault",
    "packages/*"
  ],
  "scripts": {
    "dev:nexus": "npm run dev --workspace=apps/nexus",
    "dev:pathfinder": "npm run dev --workspace=apps/PathFinder",
    "dev:vault": "npm run dev --workspace=apps/Vault/Vault",
    "dev:timetracker": "npm run dev --workspace=apps/TimeTrackerApp",
    "dev:timetracker:ios": "cd apps/TimeTrackerApp && npx tauri ios dev",
    "dev:vault:ios": "cd apps/Vault/Vault && npx tauri ios dev",
    "build:vault:ios": "cd apps/Vault/Vault && npx tauri ios build",
    "dev:stonks": "npm run dev --workspace=apps/Stonks",
    "dev:protocol": "npm run dev --workspace=apps/Protocol",
    "build:all": "npm run build --workspaces --if-present",
    "lint:all": "npm run lint --workspaces --if-present",
    "ios": "./ios-build.sh",
    "ios:clean": "./ios-build.sh --clean",
    "ios:release": "./ios-build.sh --release",
    "ios:logs": "./ios-build.sh --logs",
    "ios:pathfinder": "./ios-build.sh --app pathfinder",
    "ios:vault": "./ios-build.sh --app vault"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "optionalDependencies": {
    "@esbuild/win32-x64": "^0.28.0"
  }
}
